{
  "name": "bolaomax",
  "version": "1.0.0",
  "description": "BolãoMax — Plataforma de Bolões de Loteria Online",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build":        "vite build",
    "start":        "node --import tsx/esm server.js",
    "dev":          "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web":      "vite",
    "dev:api":      "node --import tsx/esm --watch server.js",
    "db:generate":  "drizzle-kit generate --config=drizzle-postgres.config.ts",
    "db:migrate":   "node --import tsx/esm src/api/database/migrate.js",
    "db:seed":      "node --import tsx/esm src/api/database/seed-postgres.js",
    "db:studio":    "drizzle-kit studio --config=drizzle-postgres.config.ts",
    "lint":         "eslint ."
  },
  "optionalDependencies": {
    "better-sqlite3": "^12.6.2"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label":    "^2.1.8",
    "@radix-ui/react-slot":     "^1.2.4",
    "bcryptjs":                 "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx":                     "^2.1.1",
    "concurrently":             "^9.2.1",
    "cors":                     "^2.8.6",
    "tsx":                     "^4.21.0",
    "drizzle-orm":              "^0.45.1",
    "express":                  "^5.2.1",
    "jsonwebtoken":             "^9.0.3",
    "lucide-react":             "^0.562.0",
    "node-cron":                "^4.2.1",
    "pagarme":                  "^4.35.2",
    "pg":                       "^8.18.0",
    "radix-ui":                 "^1.4.3",
    "react":                    "19.2.3",
    "react-dom":                "19.2.3",
    "react-hook-form":          "^7.70.0",
    "react-icons":              "^5.5.0",
    "tailwind-merge":           "^3.4.0",
    "uuid":                     "^13.0.0",
    "wouter":                   "^3.9.0",
    "zod":                      "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js":              "9.39.2",
    "@tailwindcss/vite":       "^4.1.18",
    "@types/bcryptjs":         "^2.4.6",
    "@types/cors":             "^2.8.19",
    "@types/express":          "^5.0.6",
    "@types/jsonwebtoken":     "^9.0.10",
    "@types/node":             "^25.0.3",
    "@types/pg":               "^8.16.0",
    "@types/react":            "19.2.7",
    "@types/react-dom":        "19.2.3",
    "@vitejs/plugin-react":    "5.1.2",
    "drizzle-kit":             "^0.31.8",
    "eslint":                  "9.39.2",
    "eslint-plugin-react-hooks":"7.0.1",
    "eslint-plugin-react-refresh":"0.4.26",
    "globals":                 "17.0.0",
    "tailwindcss":             "^4.1.18",
    "tw-animate-css":          "^1.4.0",
    "vite":                    "^7.3.1"
  }
}
