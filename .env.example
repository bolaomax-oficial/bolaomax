# Variáveis de Ambiente — BolãoMax

# ─────────────────────────────────────────────
# BANCO DE DADOS
# ─────────────────────────────────────────────
# PostgreSQL (Railway — obrigatório em produção)
DATABASE_URL=postgresql://postgres:senha@host:5432/railway

# SQLite (desenvolvimento local — opcional)
# DB_PATH=./bolaomax.db

# ─────────────────────────────────────────────
# SERVIDOR
# ─────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ─────────────────────────────────────────────
# AUTENTICAÇÃO
# ─────────────────────────────────────────────
# Gere com: openssl rand -base64 32
SECRET_KEY=your-super-secret-key-here-min-32-chars

# ─────────────────────────────────────────────
# SITE
# ─────────────────────────────────────────────
SITE_URL=https://seu-app.up.railway.app
CORS_ORIGIN=https://seu-app.up.railway.app

# ─────────────────────────────────────────────
# PAGAMENTOS — Pagar.me
# ─────────────────────────────────────────────
PAGARME_API_KEY=ak_live_xxxxxx
PAGARME_ENCRYPTION_KEY=ek_live_xxxxxx
PAGARME_WEBHOOK_SECRET=webhook_secret_aqui
PAGARME_SANDBOX=true

# ─────────────────────────────────────────────
# FRONTEND (Vite — build time)
# ─────────────────────────────────────────────
VITE_API_URL=https://seu-app.up.railway.app/api
