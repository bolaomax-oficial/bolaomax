# BolãoMax - Variáveis de Ambiente

# ============================================================
# DATABASE (Railway PostgreSQL - preencher no Railway)
# ============================================================
DATABASE_URL=postgresql://user:password@host:5432/bolaomax

# ============================================================
# SERVIDOR
# ============================================================
PORT=3000
NODE_ENV=production

# ============================================================
# AUTENTICAÇÃO
# ============================================================
# Gerar com: openssl rand -base64 32
BETTER_AUTH_SECRET=GERAR_SECRET_SEGURO_AQUI
SECRET_KEY=GERAR_SECRET_SEGURO_AQUI

# ============================================================
# URLs
# ============================================================
SITE_URL=https://seu-app.up.railway.app
VITE_BASE_URL=https://seu-app.up.railway.app
CORS_ORIGIN=https://seu-app.up.railway.app

# ============================================================
# PAGAMENTOS (Pagar.me)
# ============================================================
PAGARME_API_KEY=
PAGARME_ENCRYPTION_KEY=
PAGARME_WEBHOOK_SECRET=
PAGARME_SANDBOX=true

# ============================================================
# INTEGRAÇÕES (opcional)
# ============================================================
AI_GATEWAY_BASE_URL=
AI_GATEWAY_API_KEY=
AUTUMN_SECRET_KEY=
