# ============================================================
# BOLÃOMAX - Variáveis de Ambiente
# ============================================================

# ============================================================
# DATABASE
# ============================================================

# PostgreSQL (Railway - Produção)
# Formato: postgresql://user:password@host:port/database
# Exemplo: postgresql://postgres:password123@containers-us-west-123.railway.app:5432/railway
DATABASE_URL=

# SQLite (Local - Desenvolvimento)
# Deixe vazio para usar SQLite local
DB_PATH=./bolaomax.db

# ============================================================
# SERVIDOR
# ============================================================

# Porta do servidor Express (API)
PORT=3000

# Ambiente (development | production)
NODE_ENV=development

# ============================================================
# AUTENTICAÇÃO (Better Auth)
# ============================================================

# Secret key para JWT (gerar com: openssl rand -base64 32)
SECRET_KEY=

# URL do site (para redirect após login)
SITE_URL=http://localhost:5173

# ============================================================
# PAGAMENTOS (Pagar.me - Stone)
# ============================================================

# Pagar.me API Key (obter em: https://dashboard.pagar.me)
# Sandbox: sk_test_... | Produção: sk_live_...
PAGARME_API_KEY=

# Pagar.me Encryption Key (chave pública para criptografar cartões)
# Sandbox: ek_test_... | Produção: ek_live_...
PAGARME_ENCRYPTION_KEY=

# Webhook Secret (validar webhooks)
PAGARME_WEBHOOK_SECRET=

# Ambiente (true = sandbox/teste | false = produção)
PAGARME_SANDBOX=true

# ============================================================
# FRONTEND (Vite)
# ============================================================

# URL da API (para o frontend acessar)
VITE_API_URL=http://localhost:3000/api

# Pagar.me Encryption Key (frontend - chave pública)
VITE_PAGARME_ENCRYPTION_KEY=

# ============================================================
# LOGS E MONITORAMENTO
# ============================================================

# Nível de log (debug | info | warn | error)
LOG_LEVEL=info

# ============================================================
# RAILWAY (Produção)
# ============================================================

# Estas variáveis são configuradas automaticamente pelo Railway
# RAILWAY_ENVIRONMENT=production
# RAILWAY_PROJECT_ID=
# RAILWAY_SERVICE_ID=
