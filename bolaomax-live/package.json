    "tw-animate-css": "^1.4.0",
    "vite": "^7.3.1",
    "wrangler": "^4.58.0"
  },
  "scripts": {
    "build": "vite build",
    "cf-typegen": "wrangler types",
    "check": "tsgo && vite build && wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "dev": "vite",
    "dev:api": "node server-express.js",
    "dev:full": "concurrently \"npm run dev:api\" \"npm run dev\"",
    "start": "node server-express.js",
    "lint": "eslint .",
    "preview": "bun run build && vite preview",
    "db:generate": "drizzle-kit generate",
    "db:generate:pg": "drizzle-kit generate --config=drizzle-postgres.config.ts",
    "db:migrate": "wrangler d1 migrations apply DB --local",
    "db:migrate:pg": "node -e \"import('./src/api/database/migrate-postgres.js').then(m => m.migrate())\"",
    "db:seed:pg": "node src/api/database/seed-postgres.js",
    "db:studio": "drizzle-kit studio"
  },
  "type": "module"
}
