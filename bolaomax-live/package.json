    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260109.1",
    "@vitejs/plugin-react": "5.1.2",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.8",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.26",
    "globals": "17.0.0",
    "jsonwebtoken": "^9.0.3",
